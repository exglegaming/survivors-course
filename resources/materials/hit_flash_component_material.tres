[gd_resource type="ShaderMaterial" format=3 uid="uid://da72e8a0lqsaq"]

[sub_resource type="Shader" id="Shader_k8bxp"]
resource_local_to_scene = true
code = "shader_type canvas_item;

uniform float lerp_percent : hint_range(0.0, 1.0);

void fragment() {
	vec4 texture_color = texture(TEXTURE, UV);
	vec4 final_color = mix(texture_color, vec4(1.0, 1.0, 1.0, texture_color.a), lerp_percent);
	COLOR = final_color;
}

"

[resource]
resource_local_to_scene = true
shader = SubResource("Shader_k8bxp")
shader_parameter/lerp_percent = 0.0
